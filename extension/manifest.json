{
  "manifest_version": 3,
  "name": "LeakLens Local Scanner",
  "version": "0.1.0",
  "description": "Local privacy scanner prototype for demo chat pages.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5500/*",
    "http://localhost:5500/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://chatgpt.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeakLens",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:5500/*",
        "http://localhost:5500/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}