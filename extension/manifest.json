{
  "manifest_version": 3,
  "name": "LeakLens Local Scanner",
  "version": "0.1.0",
  "description": "Local privacy scanner prototype for demo chat pages.",
  "permissions": [],
  "host_permissions": [
    "http://127.0.0.1:5500/*",
    "http://localhost:5500/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:5500/*",
        "http://localhost:5500/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}